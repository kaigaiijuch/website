<%= t('views.descriptions.code.title') -%>: <%= episode.title -%>


<%= t('views.descriptions.code.summary') -%>: <%= episode.long_summary %>

<% if episode.references.present? -%>
<%= t('views.descriptions.code.reference') -%>:
<% episode.references.each do |reference| -%>
  ・<%= reference.caption -%> <%= reference.link %>
<% end -%>
<% end -%>

<%= t('views.descriptions.code.subtitle') -%>: <%= episode.subtitle %>

<% episode.chapters.present? && episode.chapters.each do |chapter| -%>
<%= chapter_time(chapter) -%> <%= chapter.title %>
<% end -%>
